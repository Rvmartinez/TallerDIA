<UserControl xmlns="https://github.com/avaloniaui"
			xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			xmlns:vm="using:TallerDIA.ViewModels"
			xmlns:models="using:TallerDIA.Models"
			x:DataType="vm:ClientesViewModel"
			x:Class="TallerDIA.Views.ClientesView">
	<StackPanel>
		<StackPanel Orientation="Horizontal">
			<TextBlock Text="Lista de Clientes" FontSize="18" Margin="10" />
			<Button Content="+" Command="{Binding AddClientCommand}" />
		</StackPanel>
		<DataGrid x:Name="dgClientes" ItemsSource="{Binding Clientes}"
          BorderThickness="1" BorderBrush="Gray" CanUserReorderColumns="False" IsReadOnly="True" SelectedItem="{Binding SelectedClient}">
			<DataGrid.Columns>
				<DataGridTextColumn Header="ID"  Binding="{Binding IdCliente}"/>
				<DataGridTextColumn Header="DNI"  Binding="{Binding DNI}"/>
				<DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" />
				<DataGridTextColumn Header="Email" Binding="{Binding Email}" />
			</DataGrid.Columns>
		</DataGrid>
	</StackPanel>
</UserControl>
