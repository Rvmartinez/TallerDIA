<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ProyectoTallerAvalonia.MainWindow"
        Title="ProyectoTallerAvalonia">
    <StackPanel Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Button Name="BtnEmpezar" Content="Empezar gestion de coches" Width="300" Height="30" Click="OnClickEmpezar"/>
    </StackPanel>
</Window>
