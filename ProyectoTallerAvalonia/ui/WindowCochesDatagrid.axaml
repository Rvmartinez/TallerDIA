<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ProyectoTallerAvalonia.WindowCochesDatagrid"
        Title="ProyectoTallerAvalonia">
    <StackPanel Name="StackDatagrid" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
        <DataGrid Name="DatagridCoches" AutoGenerateColumns="False" x:CompileBindings="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Matricula"  Binding="{Binding Matricula}"/>
                <DataGridTextColumn Header="Marca"  Binding="{Binding Marca}"/>
                <DataGridTextColumn Header="Modelo" Binding="{Binding Modelo}" />
            </DataGrid.Columns>
        </DataGrid>
        <Button Name="Salir" Content="Salir" Click="cerrarVentana" HorizontalAlignment="Center"></Button>
        <Label Name="ErroresDatagrid" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
    </StackPanel>
    
</Window>
